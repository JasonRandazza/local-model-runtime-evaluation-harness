              "mlx-community/gemma-4-12B-it-qat-OptiQ-4bit"
            ]
          },
          "routed_model_id": {
            "const": "optiq//Users/jrazz/.cache/huggingface/hub/mlx-community/gemma-4-12B-it-qat-OptiQ-4bit:no-think"
          },
          "rejected_local_model_ids": {"const": [
            "gemma-4-12b-optiq-4bit",
