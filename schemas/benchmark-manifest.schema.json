        "suite_revision": {"const": "2"}, "repetitions": {"const": 5}, "route_order": {"const": "counterbalanced"},
        "routes": {"const": {"direct": "http://127.0.0.1:8100/v1", "routed": "http://127.0.0.1:1337/v1"}},
        "limits": {"type": "object", "additionalProperties": false, "required": ["request_timeout_seconds", "memory_stop_level"], "properties": {"request_timeout_seconds": {"type": "integer", "minimum": 1}, "memory_stop_level": {"const": "critical"}}}
      }
    },
    {
      "type": "object",
