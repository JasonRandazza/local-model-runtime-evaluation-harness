        "suite_id": {"const": "gemma-optiq-route-benchmark-v1"}, "suite_revision": {"const": "1"},
        "repetitions": {"const": 1}, "route_order": {"const": "counterbalanced"},
        "routes": {"const": {"direct": "http://127.0.0.1:8080/v1", "routed": "http://127.0.0.1:1337/v1"}},
