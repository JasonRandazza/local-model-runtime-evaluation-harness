      "additionalProperties": false,
      "required": ["schema_version", "run_id", "stage", "mode", "operations", "output_root", "approved_by", "approved_at", "expires_at", "simulation"],
      "properties": {
        "schema_version": {"const": "1.0.0"}, "run_id": {"type": "string", "pattern": "^stage0-[0-9]{8}-[0-9]{3}$"},
        "stage": {"const": 0}, "mode": {"const": "dry_run"}, "operations": {"$ref": "#/$defs/operations"},
        "output_root": {"$ref": "#/$defs/output_root"}, "approved_by": {"type": "string", "minLength": 1},
        "approved_at": {"type": "string", "format": "date-time"}, "expires_at": {"type": "string", "format": "date-time"},
        "simulation": {"const": {"pause_after": "running"}}
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "run_id", "stage", "mode", "operations", "output_root", "approved_by", "approved_at", "expires_at", "comparison_class", "model_profile_id", "model_profile_revision", "suite_id", "suite_revision", "repetitions", "route_order", "routes", "limits"],
      "properties": {
        "schema_version": {"const": "2.0.0"}, "run_id": {"type": "string", "pattern": "^stage1-[0-9]{8}-[0-9]{3}$"},
